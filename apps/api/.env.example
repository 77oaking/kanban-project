# --- Database ---
# Locally: postgresql://USER:PASSWORD@localhost:5432/fredocloud
# On Railway, the Postgres plugin injects this automatically.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fredocloud

# --- Server ---
PORT=4000
NODE_ENV=development

# --- Auth (JWT) ---
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace_me_with_a_long_random_string
JWT_REFRESH_SECRET=replace_me_with_another_long_random_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- Frontend origin (for CORS + redirects) ---
CLIENT_URL=http://localhost:3000

# --- Cloudinary (avatars + attachments) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Email (optional) ---
# Without these, invitation/mention emails are logged to the console instead
# of sent. Works with any SMTP — recommended free options:
#   - Resend: smtp.resend.com:587, user "resend", pass "<API_KEY>"
#   - Mailtrap (testing inbox): sandbox.smtp.mailtrap.io:2525
#   - Gmail (less reliable, requires app password)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="FredoCloud Team Hub <noreply@fredocloud.test>"

# --- Demo seed account (optional override) ---
DEMO_EMAIL=demo@fredocloud.test
DEMO_PASSWORD=Demo1234!
